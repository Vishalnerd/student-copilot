{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "types": ["jest","node"]
  },

  "include": ["server.ts", "src/**/*.ts"],
  "exclude": ["node_modules"]
}